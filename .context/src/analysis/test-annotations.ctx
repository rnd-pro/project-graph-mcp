@sig e05b5440
findCtxMdFiles(dir:string)→readdirSync,join,statSync,stat.isDirectory,entry.startsWith,findCtxMdFiles|recursively find .ctx.md files in dir
export parseAnnotations(content:string,filePath:string)→content.split,line.startsWith,groupByName,features.push,line.match,rest.split|parse checklist lines into test feature objects
groupByName(tests,filePath:string)→Object.entries|group parsed tests by feature name
export getAllFeatures(dir:string)→resolve,join,findCtxMdFiles,readFileSync,parseAnnotations,features.push|read and parse all test features from context dir
export getPendingTests(dir:string)→resolve,getAllFeatures,relative,pending.push|return list of pending tests with file paths
export markTestPassed(testId:string)→testId.split,updateTestState|mark specific test id as passed [x]
export markTestFailed(testId:string,reason:string)→testId.split,updateTestState|mark specific test id as failed [!] with reason
updateTestState(name:string,testId:string,newState,reason:string)→process.cwd,join,findCtxMdFiles,testId.split,parseInt,readFileSync|update test state string in .ctx.md file
export getTestSummary(dir:string)→getAllFeatures,failures.push,Math.round|compute total, passed, failed, pending counts
export resetTestState()→process.cwd,join,findCtxMdFiles,readFileSync,content.replace,writeFileSync|reset all test states to pending [ ]
PATTERNS: regex markdown checklist parsing|file rewriting for state
EDGE_CASES: handles unreadable files gracefully|handles missing failure reasons
