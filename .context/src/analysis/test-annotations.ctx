findCtxMdFiles(t)→e,o,s,r.startsWith,findCtxMdFiles,n.push|recursively find .ctx.md files in dir
export parseAnnotations(t,e)→t.split,t.startsWith,groupByName,n.push,t.match,c.split|parse checklist lines into test feature objects
groupByName(t,e)→Object.entries|group parsed tests by feature name
export getAllFeatures(e)→a,o,findCtxMdFiles,t,parseAnnotations,n.push|read and parse all test features from context dir
export getPendingTests(t)→a,getAllFeatures,r,n.push|return list of pending tests with file paths
export markTestPassed(t)→t.split,updateTestState|mark specific test id as passed [x]
export markTestFailed(t,e)→t.split,updateTestState|mark specific test id as failed [!] with reason
updateTestState(e,s,r,a)→process.cwd,o,findCtxMdFiles,s.split,parseInt,t|update test state string in .ctx.md file
export getTestSummary(t)→getAllFeatures,a.push,Math.round|compute total, passed, failed, pending counts
export resetTestState()→process.cwd,o,findCtxMdFiles,t,s.replace,n|reset all test states to pending [ ]
PATTERNS: regex markdown checklist parsing|file rewriting for state
EDGE_CASES: handles unreadable files gracefully|handles missing failure reasons
