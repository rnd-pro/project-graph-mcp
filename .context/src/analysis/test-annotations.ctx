--- src/analysis/test-annotations.js ---
@sig b2010e5d
export parseAnnotations(content,filePath)→t.split,t.startsWith,i,n.push,t.match,f.split|parse checklist lines into test feature objects
export getAllFeatures(dir)→c,o,a,t,parseAnnotations,n.push|read and parse all test features from context dir
export getPendingTests(dir)→c,getAllFeatures,r,n.push|return list of pending tests with file paths
export markTestPassed(testId)→t.split,f|mark specific test id as passed [x]
export markTestFailed(testId,reason)→t.split,f|mark specific test id as failed [!] with reason
export getTestSummary(dir)→getAllFeatures,c.push,Math.round|compute total, passed, failed, pending counts
export resetTestState()→process.cwd,o,a,t,e.replace,n|reset all test states to pending [ ]
PATTERNS: regex markdown checklist parsing|file rewriting for state
EDGE_CASES: handles unreadable files gracefully|handles missing failure reasons
