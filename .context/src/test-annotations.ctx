findCtxMdFiles(dir)→readdirSync,join,statSync,stat.isDirectory,entry.startsWith,findCtxMdFiles|{DESCRIBE}
export parseAnnotations(content,filePath)→content.split,line.startsWith,groupByName,features.push,line.match,rest.split|{DESCRIBE}
groupByName(tests,filePath)→Object.entries|{DESCRIBE}
export getAllFeatures(dir)→resolve,join,findCtxMdFiles,readFileSync,parseAnnotations,features.push|{DESCRIBE}
export getPendingTests(dir)→resolve,getAllFeatures,relative,pending.push|{DESCRIBE}
export markTestPassed(testId)→testId.split,updateTestState|{DESCRIBE}
export markTestFailed(testId,reason)→testId.split,updateTestState|{DESCRIBE}
updateTestState(name,testId,newState,reason)→process.cwd,join,findCtxMdFiles,testId.split,parseInt,readFileSync|{DESCRIBE}
export getTestSummary(dir)→getAllFeatures,failures.push,Math.round|{DESCRIBE}
