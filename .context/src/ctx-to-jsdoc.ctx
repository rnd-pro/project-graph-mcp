walkJSFiles(dir:string)→string[]→readdirSync,entry.startsWith,join,statSync,stat.isDirectory,SKIP_DIRS.has|walk dir for JS/MJS files, skip node_modules/vendor/.git
export parseCtxFile(ctxContent:string)→{ file: string|null, functions: Array<{name: string, params: string, exported: boolean, description: string→ctxContent.split,line.match,arrowParts.split,desc.trim,functions.push|parse .ctx file into structured fn signatures with params+types
buildJSDocBlock(funcInfo:{ name: string, params: string, exported: boolean, description: string })→string→lines.push,params.split,p.trim,param.match,lines.join|build JSDoc /** */ block from ctx fn info with @param/@returns
findCtxFile(sourceFile:string,projectRoot:string)→string|null→sourceFile.replace,join,existsSync|locate .ctx file for source: check .context/ dir first, then colocated
findExportStart(funcNode)|find real start position for exported fns (before export keyword)
export injectJSDoc(dir:string,options:Object=)→{ files: number, injected: number, skipped: number, details: Array →walkJSFiles,relative,findCtxFile,readFileSync,parseCtxFile,parse|inject JSDoc from .ctx into source, skip if JSDoc exists, AST-located
export stripJSDoc(dir:string,options:Object=)→{ files: number, stripped: number, savedBytes: number →walkJSFiles,readFileSync,parse,value.startsWith,comments.filter,stripped.slice|strip all JSDoc via AST comments (safe—ignores strings), regex fallback
export validateCtxContracts(dir:string,options:Object=)→{ files: number, violations: Array<{file: string, severity: string, message: string→walkJSFiles,relative,findCtxFile,readFileSync,parseCtxFile,parse|{DESCRIBE}
PATTERNS: AST-based comment detection via Acorn onComment array|reverse-order insertions preserve line numbers|export keyword detection for duplicate prevention
EDGE_CASES: strings containing /** preserved by AST parser|blank lines between JSDoc and fn handled by trimEnd|unparseable files fall back to regex strip
