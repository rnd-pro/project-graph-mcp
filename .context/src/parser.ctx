export parseFile(code,filename)→parse,console.warn,buildJSDocTypeMap,imports.push,exportedNames.add,methods.push|parse single JS file to AST|extracts classes,functions,imports,exports
extractCallsAndSQL(node,calls,dbReads,dbWrites)→calls.includes,calls.push,getCallMethodName,DB_METHODS.has,extractStringValue,isSQLString|walk AST to extract method calls and SQL queries
getTagName(tag)|null|null|null|extract tag name from tagged template expr|handles sql,Prisma.sql,db.sql
getCallMethodName(callNode)|null|null|null|extract method name from CallExpression callee
extractStringValue(node)→templateToString|null→templateToString|null→templateToString|null→templateToString|extract string from Literal or TemplateLiteral|replaces $N placeholders
templateToString(tplNode)|convert TemplateLiteral AST node to string with $N
export discoverSubProjects(rootDir)→resolve,join,existsSync,readdirSync,statSync,readFileSync|find sub-projects in known monorepo directories
export parseProject(dir,options=)→resolve,findJSFiles,readFileSync,relative,parseFileByExtension,files.push|parse all JS files in dir|returns aggregated ParseResult
parseFileByExtension(code,filename)→filename.endsWith,parseSQL,parsePython,parseGo,parseTypeScript,parseFile|route file to correct parser based on extension
isSourceFile(filename)→filename.endsWith,SOURCE_EXTENSIONS.some|check if file extension is supported|excludes .css.js,.tpl.js
buildJSDocTypeMap(comments,code)→value.startsWith,code.slice,paramStartRegex.exec,text.slice,afterType.match,name.startsWith|build map of line numbers to JSDoc param/return types
findJSDocForNode(jsdocMap,funcLine)→jsdocMap.get|lookup JSDoc entry for AST node by line number
enrichParamsWithTypes(rawParams,jsdoc)→typeMap.set,param.startsWith,param.endsWith,cleanName.slice,typeMap.get,type.startsWith|merge raw AST params with parsed JSDoc type info
PATTERNS: AST visitor via walk.simple|extension-based parser routing
EDGE_CASES: ignores parse errors (returns empty)|excludes specific presentation files