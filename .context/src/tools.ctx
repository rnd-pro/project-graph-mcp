--- src/tools.js ---
@sig a77a9874
saveDiskCache()→join,Object.fromEntries,JSON.stringify,writeFileSync|save graph cache to disk|.project-graph-cache.json
loadDiskCache()→join,existsSync,readFileSync,JSON.parse,cachedMtimes.clear,Object.entries|load graph cache from disk|validates version and path
export getGraph()→detectChanges,loadDiskCache,parseProject,buildGraph,snapshotMtimes,saveDiskCache|get or build project graph|uses smart mtime-based caching
detectChanges()→findJSFiles,cachedMtimes.keys,cachedSet.has,currentSet.has,statSync,cachedMtimes.get|detect if any JS files changed via mtime
snapshotMtimes()→cachedMtimes.clear,findJSFiles,statSync,cachedMtimes.set|snapshot mtimes for all JS files in path
export getSkeleton()→getGraph,createSkeleton|get compact project skeleton
export getFocusZone()→getGraph,execSync,diff.split,f.endsWith,readFileSync,parseFile|get enriched focus zone|auto-detects from git diff or recent files
export expand()→getGraph,symbol.split,parseProject,classes.find,functions.find,readFileSync|expand minified symbol to full details|extracts method code if specified
export deps()→getGraph,edges.filter|get dependency tree for a symbol|shows imports, usedBy, calls
export usages()→getGraph,parseProject,calls.includes,c.includes,calls.some,results.push|find all usages of a symbol across project
extractMethod()→regex.exec,content.slice|extract method code from file content using regex
export getCallChain()→getGraph,caller.push,visitedNodes.add,queue.shift,current.split,sym.split|find shortest call path between two symbols|uses BFS
export invalidateCache()→join,existsSync,unlinkSync,cachedMtimes.clear|delete cache file and clear memory cache
PATTERNS: smart mtime caching|BFS for call chain|regex for method extraction
EDGE_CASES: gracefully handles unreadable files/mtimes|handles missing symbols
